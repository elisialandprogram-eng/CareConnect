# GoldenLife — Environment Variable Reference
# Copy this file to .env and fill in your values.
# Required vars cause immediate startup abort if missing.
# Optional vars degrade gracefully (features disabled, warning logged).

# ── Required ──────────────────────────────────────────────────────────────────
# Either SUPABASE_DATABASE_URL (preferred for production) or DATABASE_URL must be set.
SUPABASE_DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT signing key — must be at least 32 random characters; never use the default.
SESSION_SECRET=change-me-to-a-random-32-plus-char-string

# ── Payments (Stripe) — optional; payments fail gracefully if missing ─────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) — optional; transactional email skipped if missing ─────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── File Storage (Cloudinary) — optional; uploads disabled if missing ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── SMS / WhatsApp (Twilio) — optional ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# ── Video calls (Daily.co) — optional, falls back to Jitsi links ─────────────
DAILY_API_KEY=
DAILY_DOMAIN=

# ── Web Push notifications (VAPID) ────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com

# ── AI assistant (OpenAI via Replit) — optional; chat assistant disabled ──────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# ── Google Maps — optional; location features fall back to text only ──────────
GOOGLE_MAPS_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Data retention window overrides (days) — optional ────────────────────────
# RETAIN_NOTIFICATIONS_DAYS=90
# RETAIN_SYSTEM_EVENTS_DAYS=90
# RETAIN_AUDIT_LOGS_DAYS=180
