# Database
DATABASE_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Twilio — SMS + WhatsApp (optional; channels no-op if absent)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=

# Web Push (VAPID) — generate via `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@example.com

# Daily.co — Video visits (optional; falls back to placeholder URL)
DAILY_API_KEY=

# Frontend
VITE_PUBLIC_VAPID_KEY=
